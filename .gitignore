# ============================================
# 🚨 SECRETS — never commit these
# ============================================
secrets/
*.env
*.env.*
!*.env.example
.dev.vars
local.properties
google-services.json
*-firebase-adminsdk-*.json
*.keystore
*.jks

# ============================================
# 🚨 PERSONAL DATA (PIPA) — never commit these
# ============================================
# Captain interview transcripts contain personal data about real humans.
notes/captain-interview-*.md
# Real KakaoBank Excel exports contain member names + financial transactions.
scratchpad/02_excel_parse/samples/

