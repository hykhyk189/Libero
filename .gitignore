# ============================================
android/build/
android/app/build/
android/.gradle/
android/.idea/
android/captures/
android/.cxx/
android/local.properties
android/app/release/
*.iml
*.apk
*.ap_
*.aab
*.dex
*.class
bin/
gen/
out/
release/

# ============================================
# Gradle (top-level — catches scratchpad gradle dirs)
# ============================================
.gradle/

# ============================================
# Bun / Node (for scratchpad + edge functions)
# ============================================
node_modules/
.bun/
dist/
*.tsbuildinfo

