.DS_Store
.AppleDouble
.LSOverride

# ============================================
# IDE
# ============================================
# Track .vscode/settings.json (Supabase Deno LSP scope) and extensions.json,
# ignore everything else under .vscode/ (per-developer prefs).
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ============================================
# Logs
# ============================================
*.log
npm-debug.log*
bun-debug.log*

# ============================================
# Build artifacts
# ============================================
build/
out/
